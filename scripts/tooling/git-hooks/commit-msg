#!/usr/bin/env bash
set -euo pipefail

MSG_FILE="${1:?}"
MSG="$(cat "$MSG_FILE")"

if [[ "${HAPI_SKIP_COMMIT_HOOKS:-}" == "1" ]]; then
    exit 0
fi

if printf '%s' "$MSG" | grep -qiE \
    'jessica-mood|jessica_mood|SOUL\.md|SOUL_SESSION|AGENTS\.local|docs/operator|docs/plans|localdocs/|co-authored-by:[[:space:]]*cursor'; then
    echo "commit-msg: forbidden reference in message (persona / fork-private)" >&2
    exit 1
fi

exit 0
