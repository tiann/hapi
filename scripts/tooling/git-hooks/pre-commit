#!/usr/bin/env bash
# Fork commit gate — tiered: operator/tooling OK; plans local-first; never-tracked blocked.
# Install: scripts/tooling/install-git-hooks.sh
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"
LEAK_CHECK="$ROOT/scripts/tooling/check-operator-leaks.sh"
POLICY="$ROOT/scripts/tooling/lib/fork-path-policy.sh"
# shellcheck source=/dev/null
source "$POLICY"

if [[ "${HAPI_SKIP_COMMIT_HOOKS:-}" == "1" ]]; then
    exit 0
fi

STAGED="$(git diff --cached --name-only --diff-filter=ACMR)"
if [[ -z "$STAGED" ]]; then
    exit 0
fi

FAIL=0

report() {
    echo "pre-commit: $1" >&2
    FAIL=1
}

while IFS= read -r path; do
    [[ -z "$path" ]] && continue
    if ! fork_pre_commit_path_ok "$path"; then
        reason="$(fork_pre_commit_block_reason "$path")"
        report "$reason"
    fi
    case "$path" in
        .env|.env.*|hub/.env|hub/.env.*|*/.env|*/.env.*|hub/.env~|*/hub/.env~)
            report "env file blocked: $path"
            ;;
        AGENTS.local.md|*/AGENTS.local.md)
            report "AGENTS.local.md blocked: $path"
            ;;
        *~)
            report "backup file blocked: $path"
            ;;
        *jessica-mood*|*jessica_mood*)
            report "fork-only route path blocked: $path"
            ;;
    esac
done <<< "$STAGED"

# Forbidden content in staged product diff (not docs paths)
CONTENT_PATTERNS=(
    'jessica-mood'
    'jessica_mood'
    'SOUL_SESSION'
    'SOUL\.md'
    '~/coding/SOUL'
    'AGENTS\.local'
    'localdocs/'
)

SCAN_PATHS=(hub web cli shared package.json)
for pattern in "${CONTENT_PATTERNS[@]}"; do
    if git diff --cached -G"$pattern" --quiet -- "${SCAN_PATHS[@]}" 2>/dev/null; then
        continue
    fi
    if [[ "${HAPI_ALLOW_OPERATOR_COMMIT:-}" == "1" ]]; then
        echo "pre-commit: WARN content match $pattern (HAPI_ALLOW_OPERATOR_COMMIT=1)" >&2
        continue
    fi
    report "staged product content matches: $pattern"
    git diff --cached -G"$pattern" --name-only -- "${SCAN_PATHS[@]}" 2>/dev/null | sed 's/^/    /' >&2 || true
done

while IFS= read -r path; do
    [[ -z "$path" ]] && continue
    case "$path" in
        hub/*jessica*|web/*jessica-mood*)
            if git diff --cached -- "$path" 2>/dev/null | grep -qi 'jessica'; then
                report "jessica reference in fork route file: $path"
            fi
            ;;
    esac
done <<< "$STAGED"

SECRET_PATTERNS=(
    'CLI_API_TOKEN=[^[:space:]]+'
    'ELEVENLABS_API_KEY=[^[:space:]]+'
    'GEMINI_API_KEY=[^[:space:]]+'
    'OPENAI_API_KEY=[^[:space:]]+'
    'sk-[A-Za-z0-9]{20,}'
    'ghp_[A-Za-z0-9]{20,}'
)

for pattern in "${SECRET_PATTERNS[@]}"; do
    if git diff --cached -G"$pattern" --quiet -- "${SCAN_PATHS[@]}" 2>/dev/null; then
        continue
    fi
    report "possible secret in staged product diff ($pattern)"
    git diff --cached -G"$pattern" --name-only -- "${SCAN_PATHS[@]}" 2>/dev/null | sed 's/^/    /' >&2 || true
done

if [[ -x "$LEAK_CHECK" ]]; then
    if ! "$LEAK_CHECK" --git-staged; then
        FAIL=1
    fi
    # Staged docs going to GitHub must not add new tailnet hostnames
    if ! "$LEAK_CHECK" --git-staged-docs; then
        FAIL=1
    fi
fi

if [[ "$FAIL" -ne 0 ]]; then
    echo "" >&2
    fork_policy_github_safe_paths >&2
    echo "Emergency: HAPI_SKIP_COMMIT_HOOKS=1  |  docs/plans only: HAPI_ALLOW_OPERATOR_COMMIT=1" >&2
    exit 1
fi

exit 0
