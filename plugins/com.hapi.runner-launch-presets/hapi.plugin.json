{
    "id": "com.hapi.runner-launch-presets",
    "version": "0.1.1",
    "name": "Runner Launch Presets",
    "description": "First-party Runner plugin for applying default launch settings by agent and workspace.",
    "display": {
        "name": {
            "en": "Runner Launch Presets",
            "zh-CN": "Runner 启动预设"
        },
        "description": {
            "en": "Applies default model, reasoning, and permission settings for Runner launches by agent and workspace.",
            "zh-CN": "按 Agent 和工作区为 Runner 启动自动应用默认模型、思考强度和权限设置。"
        },
        "featureIntro": {
            "en": "- Applies launch defaults before agent command args are built.\n- Matches all agents/workspaces or selected agents and workspace prefixes.\n- Supports model, Claude effort, Codex reasoning effort, and permission/yolo defaults.\n- User-selected fields in the New Session UI override presets.",
            "zh-CN": "- 在构建 agent 启动参数前应用默认值。\n- 可匹配全部或指定 Agent、指定工作区前缀。\n- 支持模型、Claude effort、Codex reasoning effort、权限/yolo 默认值。\n- 新建会话 UI 中用户手动选择的字段优先。"
        }
    },
    "capabilities": [
        {
            "id": "runner-launch-presets",
            "kind": "runner.spawnExtension",
            "displayName": "Runner Launch Presets",
            "description": "Applies configured launch defaults before an agent process starts.",
            "display": {
                "name": {
                    "en": "Runner Launch Presets",
                    "zh-CN": "Runner 启动预设"
                },
                "description": {
                    "en": "Applies configured launch defaults before an agent process starts.",
                    "zh-CN": "在 agent 进程启动前应用启动默认值。"
                }
            },
            "parts": {
                "web": {
                    "required": true,
                    "contributions": [
                        {
                            "type": "settingsPanel",
                            "id": "runner-launch-presets"
                        }
                    ]
                },
                "runner": {
                    "required": true,
                    "target": "selected-runner",
                    "contributions": [
                        {
                            "type": "spawnOptionsProvider",
                            "id": "runner-launch-presets"
                        }
                    ]
                }
            }
        }
    ],
    "runtimes": {
        "runner": {
            "entry": "src/runner.js"
        }
    },
    "contributions": {
        "runner": {
            "spawnOptionsProviders": [
                {
                    "id": "runner-launch-presets",
                    "displayName": "Runner Launch Presets",
                    "description": "Applies default launch options before command args are built.",
                    "display": {
                        "name": {
                            "en": "Runner Launch Presets",
                            "zh-CN": "Runner 启动预设"
                        },
                        "description": {
                            "en": "Applies default launch options before command args are built.",
                            "zh-CN": "在构建命令参数前应用启动默认值。"
                        }
                    }
                }
            ]
        },
        "web": {
            "settingsPanels": [
                {
                    "id": "runner-launch-presets",
                    "title": {
                        "en": "Runner Launch Presets",
                        "zh-CN": "Runner 启动预设"
                    },
                    "description": {
                        "en": "Set default launch options by agent and workspace. User choices in New Session override these defaults.",
                        "zh-CN": "按 Agent 和工作区设置默认启动参数。新建会话中用户手动选择的值会覆盖预设。"
                    },
                    "components": [
                        {
                            "id": "runner-launch-presets-editor",
                            "kind": "runnerSpawnDefaultsEditor",
                            "configKey": "rulesJson"
                        }
                    ]
                }
            ]
        }
    },
    "compatibility": {
        "pluginApi": ">=0.1 <0.2",
        "hub": {
            "extensionPoints": [
                "web.settingsPanel"
            ]
        },
        "runner": {
            "extensionPoints": [
                "runner.spawnOptionsProvider"
            ]
        }
    },
    "install": {
        "runnerPlacement": "compatible-runners",
        "offlineRunnerPolicy": "skip",
        "minReadyRunnerCount": 1
    },
    "pluginApiVersion": "0.1"
}
