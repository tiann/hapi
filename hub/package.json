{
    "name": "hapi-hub",
    "private": true,
    "version": "0.1.0",
    "description": "Telegram Bot client for HAPI - control Claude Code sessions",
    "author": "weishu",
    "license": "AGPL-3.0-only",
    "type": "module",
    "exports": {
        "./startHub": {
            "types": "./src/startHub.d.ts",
            "default": "./src/startHub.ts"
        }
    },
    "scripts": {
        "start": "bun run src/index.ts",
        "dev": "bun --watch run src/index.ts",
        "test": "bun test",
        "typecheck": "tsc --noEmit",
        "build": "bun build src/index.ts --outdir dist --target bun",
        "generate:embedded-web-assets": "bun run scripts/generate-embedded-web-assets.ts"
    },
    "dependencies": {
        "@hapi/protocol": "workspace:*",
        "@socket.io/bun-engine": "^0.1.1",
        "grammy": "^1.44.0",
        "hono": "^4.12.27",
        "jose": "^6.2.3",
        "qrcode": "^1.5.4",
        "socket.io": "^4.8.3",
        "web-push": "^3.6.7",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@types/node": "^26.1.0",
        "@types/qrcode": "^1.5.6",
        "@types/web-push": "^3.6.4",
        "bun-types": "^1.3.14",
        "typescript": "^6.0.3"
    }
}
