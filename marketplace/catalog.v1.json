        {
            "id": "com.hapi.schedule-send",
            "name": "Schedule Send",
            "display": {
                "name": {
                    "en": "Schedule Send",
                    "zh-CN": "定时发送"
                },
                "description": {
                    "en": "Adds a delay picker to the chat composer and routes scheduled delivery through the Hub.",
                    "zh-CN": "在聊天输入框添加延迟发送选择器，并通过 Hub 可靠投递队列安排发送。"
                },
                "featureIntro": {
                    "en": "- Adds a delay picker to the chat composer.\n- Validates scheduled-message requests in the Hub runtime.\n- Uses HAPI reliable delivery so queued messages survive reloads.",
                    "zh-CN": "- 在聊天输入框提供延迟发送选择器。\n- 由 Hub 运行时校验定时消息请求。\n- 使用 HAPI 可靠投递队列，重载后仍可继续发送。"
                }
            },
            "description": "First-party cross-runtime plugin that contributes a Web composer action and a Hub message-action handler backed by the core reliable delivery queue.",
            "repo": "tiann/hapi",
            "homepage": "https://github.com/tiann/hapi",
            "author": {
                "name": "HAPI",
                "url": "https://github.com/tiann/hapi"
            },
            "license": "AGPL-3.0-only",
            "categories": [
                "chat",
                "utility"
            ],
            "keywords": [
                "schedule",
                "delay",
                "chat",
                "message-action",
                "reliable-delivery"
            ],
            "runtimes": [
                "hub"
            ],
            "capabilities": [
                {
                    "kind": "chat.composer.messageAction",
                    "label": "Schedule Send"
                }
            ],
