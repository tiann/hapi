# Docker 本地运行示例配置
# 复制为 .env 后按需修改：cp .env.example .env

# 必填：hub 与 runner 共用的认证密钥
CLI_API_TOKEN=change-me

# 必填：宿主机 Claude 配置目录的绝对路径
CLAUDE_CONFIG_DIR=/absolute/path/to/your/.claude

# 可选：hub 暴露端口与公开地址
ZS_LISTEN_PORT=3006
ZS_PUBLIC_URL=http://localhost:3006

# 可选：runner 连接 hub 的地址（compose 内默认即可）
ZS_API_URL=http://zs-hub:3006

# 可选：运行时工具链版本
ZS_GO_VERSION=1.24.3
ZS_NODE_VERSION=22

# 可选：Claude / ZCF 运行时覆盖
# 注意：ZCF_API_KEY 必须是 token，ZCF_API_URL 必须是 http(s):// URL
ZCF_API_KEY=
ZCF_API_URL=
ZCF_API_MODEL=
ZCF_API_HAIKU_MODEL=
ZCF_API_SONNET_MODEL=
ZCF_API_OPUS_MODEL=
ZCF_DEFAULT_OUTPUT_STYLE=
ZCF_ALL_LANG=
ZCF_AI_OUTPUT_LANG=
