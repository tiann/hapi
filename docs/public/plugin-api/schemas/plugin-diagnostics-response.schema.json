{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
        "diagnostics": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "severity": {
                        "type": "string",
                        "enum": [
                            "info",
                            "warning",
                            "error"
                        ]
                    },
                    "code": {
                        "type": "string",
                        "minLength": 1
                    },
                    "message": {
                        "type": "string",
                        "minLength": 1
                    },
                    "path": {
                        "type": "string"
                    },
                    "pluginId": {
                        "type": "string"
                    },
                    "target": {
                        "type": "object",
                        "properties": {
                            "scope": {
                                "anyOf": [
                                    {
                                        "type": "string",
                                        "const": "hub"
                                    },
                                    {
                                        "type": "string",
                                        "const": "all-runners"
                                    },
                                    {
                                        "type": "string",
                                        "pattern": "^runner:[A-Za-z0-9][A-Za-z0-9._-]*$"
                                    }
                                ]
                            },
                            "runtime": {
                                "type": "string",
                                "enum": [
                                    "hub",
                                    "runner"
                                ]
                            },
                            "machineId": {
                                "type": "string",
                                "minLength": 1,
                                "maxLength": 256,
                                "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
                            },
                            "displayName": {
                                "type": "string"
                            },
                            "active": {
                                "type": "boolean"
                            },
                            "stale": {
                                "type": "boolean"
                            },
                            "updatedAt": {
                                "type": "number"
                            },
                            "hostInfo": {
                                "type": "object",
                                "properties": {
                                    "runtime": {
                                        "type": "string",
                                        "enum": [
                                            "hub",
                                            "runner"
                                        ]
                                    },
                                    "hapiVersion": {
                                        "type": "string",
                                        "minLength": 1
                                    },
                                    "pluginApiVersion": {
                                        "type": "string",
                                        "minLength": 1
                                    },
                                    "supportedPluginApiVersions": {
                                        "type": "array",
                                        "items": {
                                            "type": "string",
                                            "minLength": 1
                                        }
                                    },
                                    "os": {
                                        "type": "string",
                                        "minLength": 1
                                    },
                                    "arch": {
                                        "type": "string",
                                        "minLength": 1
                                    },
                                    "supportedExtensionPoints": {
                                        "default": [],
                                        "type": "array",
                                        "items": {
                                            "type": "string",
                                            "minLength": 1
                                        }
                                    }
                                },
                                "required": [
                                    "runtime",
                                    "hapiVersion",
                                    "pluginApiVersion",
                                    "os",
                                    "arch",
                                    "supportedExtensionPoints"
                                ],
                                "additionalProperties": false
                            },
                            "error": {
                                "type": "string"
                            }
                        },
                        "required": [
                            "scope",
                            "runtime",
                            "active"
                        ],
                        "additionalProperties": false
                    },
                    "configScope": {
                        "anyOf": [
                            {
                                "type": "string",
                                "pattern": "^hub:[A-Za-z0-9][A-Za-z0-9._-]*$"
                            },
                            {
                                "type": "string",
                                "pattern": "^runner:[A-Za-z0-9][A-Za-z0-9._-]*:[A-Za-z0-9][A-Za-z0-9._-]*$"
                            },
                            {
                                "type": "string",
                                "pattern": "^agent:[A-Za-z0-9][A-Za-z0-9._-]*:[A-Za-z0-9][A-Za-z0-9._:-]*:[A-Za-z0-9][A-Za-z0-9._-]*$"
                            }
                        ]
                    }
                },
                "required": [
                    "severity",
                    "code",
                    "message"
                ],
                "additionalProperties": false
            }
        }
    },
    "required": [
        "diagnostics"
    ],
    "additionalProperties": false
}
