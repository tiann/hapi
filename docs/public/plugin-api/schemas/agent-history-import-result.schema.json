{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
        "messages": {
            "maxItems": 10000,
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "role": {
                        "type": "string",
                        "enum": [
                            "user",
                            "agent",
                            "system"
                        ]
                    },
                    "content": {
                        "type": "string",
                        "minLength": 1,
                        "maxLength": 200000
                    },
                    "createdAt": {
                        "type": "integer",
                        "minimum": 0,
                        "maximum": 9007199254740991
                    }
                },
                "required": [
                    "role",
                    "content"
                ],
                "additionalProperties": false
            }
        }
    },
    "required": [
        "messages"
    ],
    "additionalProperties": false
}
