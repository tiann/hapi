{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
        "sourcePath": {
            "type": "string",
            "minLength": 1
        },
        "enable": {
            "type": "boolean"
        },
        "reload": {
            "type": "boolean"
        },
        "overwrite": {
            "type": "boolean"
        }
    },
    "required": [
        "sourcePath"
    ],
    "additionalProperties": false
}
