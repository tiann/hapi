# Dependencies
**/node_modules/

# Build output
**/dist/
**/.vitepress/cache/
**/dist-exe/
**/*.tsbuildinfo
hub/src/web/embeddedAssets.generated.ts
hub/src/generated/

# Downloaded tools (fetched at build time)
shared/tools/tunwg/tunwg-*
shared/tools/tunwg/*.exe

# Env files (can contain secrets)
**/.env
**/.env.*
**/.env*.local

# Logs
**/*.log
**/*-debug.log
**/*-error.log
npm-debug.log*

# Coverage
coverage/

# OS / IDE
**/.DS_Store
.idea/
.vscode/
**/*.swp
**/*.swo

# Claude local settings
.claude/settings.local.json
localdocs/
execplan/

# Generated npm bundle output (local)
cli/npm/main/
.ace-tool/

# Canonical worktree layout (2026-06-01 onward, Phase 1 / Option B).
# These subdirs are git worktrees of this same .git or operator-only shells.
# Tracked: this gitignore + worktrees/.gitkeep. Everything else under them = worktree contents.
# See docs/plans/2026-06-01-hapi-folders-reorganization.md.
/active
/driver
/upstream
/worktrees/*
!/worktrees/.gitkeep

# Cursor: ignored by global ~/.config/git/ignore but we want shared rules tracked
# in this repo. Negate the global rule for .cursor/rules/ only (per-user state
# under .cursor/ stays ignored).
!.cursor/
.cursor/*
!.cursor/rules/
!.cursor/rules/**

# Playwright e2e artifacts
test-results/
playwright-report/
e2e-output/

# Compiled output of scripts/hapi-sessions-plot.c (operator tool; rebuild via build-hapi-sessions-plot.sh)
scripts/hapi-sessions-plot
.xyz-harness
.agents/
.pi/
